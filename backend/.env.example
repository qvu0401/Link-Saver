# Example environment variables for Link Saver Backend
# Copy this to .env and update with your values

# Required for JWT token generation. Use a strong, random value (32+ bytes).
# You can generate one with: python3 -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=your-random-secret-key-here

# Token expiration time in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
